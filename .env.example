# Model Configuration
# For Docker: Use HF Hub model ID (local files won't be in container)
MODEL_PATH=facebook/bart-large-cnn
# Or use your own: MODEL_PATH=your-username/your-model-name

MAX_INPUT_LENGTH=1024
MAX_SUMMARY_LENGTH=150
MIN_SUMMARY_LENGTH=40
NUM_BEAMS=4

# App Configuration
APP_TITLE=Text Summarization using BART
DEBUG_MODE=false
LOG_LEVEL=INFO
